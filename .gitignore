# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*

# Environments
.venv/
venv/
.env

# Jupyter
.ipynb_checkpoints/

# Local editor / OS junk
.DS_Store
.idea/
.vscode/

# Output artifacts (do not commit)
logs/
out/
err/
tmp/
temp/

# In results/, ignore large raw outputs but track summaries
results/**/generated_sequences.json
results/**/samples_*.json
results/**/*.pt
results/**/*.ckpt

# Data & checkpoints (keep dir structure, not the files)
data/
checkpoints/*
!checkpoints/.gitkeep
!checkpoints/README.md
external/proseco/

# Model weight files (never commit)
*.ckpt
*.pt
*.pth
*.safetensors

# TeX / LaTeX build artifacts
*.aux
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.toc
*.run.xml
*.synctex.gz
thesis/*.aux
thesis/*.bcf
thesis/*.blg
thesis/*.bbl
thesis/*.fdb_latexmk
thesis/*.fls
thesis/*.log
thesis/*.out
thesis/*.pdf
thesis/*.toc
thesis/*.run.xml
thesis/*.synctex.gz

# Claude Code
.claude/

# HPC push.sh writes the current short SHA here so sbatches can tag outputs
# when .git is excluded from rsync. Never commit this transient file.
.hpc_git_sha

# Experiment scratch / ad hoc runs
runs/
smoke_*/
wandb/

# Generated PDF outputs under docs/
docs/pdf/**/*.pdf

# Reference paper PDFs and notes under study/
study/**/*.pdf
