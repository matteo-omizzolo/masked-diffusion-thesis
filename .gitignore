# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*

# Environments
.venv/
venv/
.env

# Jupyter
.ipynb_checkpoints/

# Local editor / OS junk
.DS_Store
.idea/
.vscode/

# Output artifacts (do not commit)
logs/
out/
err/
tmp/
temp/

# In results/, ignore large raw outputs but track summaries
results/**/generated_sequences.json
results/**/samples_*.json
results/**/*.pt
results/**/*.ckpt
# Local canonical/provenance result directories are preserved on disk and
# indexed in docs/results JSON, but are not tracked as working-tree changes.
results/*_0c39079/
results/*_nogit/
results/backend_validation/**/upstream_copy/
results/backend_validation/**/workdir/
# Large per-seed/per-shard raw JSON and NPZ features (multi-MB each).
# For ignored local result directories, promote curated summaries explicitly
# with `git add -f` only after deciding they belong in the permanent record.
results/**/validation_rows.json
results/**/neighborhood_raw*.json
results/**/triples_raw*.json
results/**/per_step_features_seed*.npz
results/**/*.npz

# Data & checkpoints (keep dir structure, not the files)
data/
checkpoints/*
!checkpoints/.gitkeep
!checkpoints/README.md
external/proseco/

# External upstream clones used for backend validation (e.g.
# lindermanlab/informed-correctors). Pinned commit is recorded in
# docs/08_backend_feasibility_audit.md, not via git.
external_repos/

# Model weight files (never commit)
*.ckpt
*.pt
*.pth
*.safetensors

# TeX / LaTeX build artifacts
*.aux
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.toc
*.run.xml
*.synctex.gz
thesis/*.aux
thesis/*.bcf
thesis/*.blg
thesis/*.bbl
thesis/*.fdb_latexmk
thesis/*.fls
thesis/*.log
thesis/*.out
thesis/*.pdf
thesis/*.toc
thesis/*.run.xml
thesis/*.synctex.gz
# latexmk save-error stubs left when a build is interrupted mid-write.
thesis/*-SAVE-ERROR
thesis/**/*-SAVE-ERROR

# Claude Code
.claude/

# HPC push.sh writes the current short SHA here so sbatches can tag outputs
# when .git is excluded from rsync. Never commit this transient file.
.hpc_git_sha

# Experiment scratch / ad hoc runs
runs/
smoke_*/
wandb/

# Generated PDF outputs under docs/
docs/pdf/**/*.pdf

# Reference paper PDFs and notes under study/
study/**/*.pdf
