# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Conda
.conda/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Logs and temporary files
logs/**/*.log
logs/**/*.err
!logs/.gitkeep
!logs/env_snapshots/.gitkeep
!logs/slurm/.gitkeep
*.tmp

# Results (keep structure, ignore data)
results/**/
!results/.gitkeep

# HPC specific
out/
err/
.tmp/

# Cache
.cache/
*.cache

# Large files
*.pt
*.pth
*.ckpt
*.safetensors
*.bin

# Environment snapshots (too large)
logs/env_snapshots/*.txt
!logs/env_snapshots/.gitkeep

# Archived files
logs/archive/
results/archive/
